{
  "name": "@openprose/reactor-cli",
  "version": "0.2.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openprose/prose.git",
    "directory": "packages/reactor-cli"
  },
  "license": "MIT",
  "type": "commonjs",
  "description": "Deterministic command-line driver for the @openprose/reactor SDK.",
  "main": "dist/cli.js",
  "bin": {
    "reactor": "dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md",
    "examples"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "prepack": "pnpm build",
    "build:test": "rm -rf dist-test && tsc -p tsconfig.test.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:runtime": "pnpm build:test && node --test $(find dist-test -name '*.test.js' -type f | sort)",
    "test": "pnpm typecheck && pnpm test:runtime",
    "test:offline": "REACTOR_OFFLINE=1 pnpm test",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "@openprose/reactor": "workspace:*"
  },
  "peerDependencies": {
    "@openai/agents": "*",
    "zod": "*"
  },
  "peerDependenciesMeta": {
    "@openai/agents": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@openprose/reactor": "workspace:*",
    "@types/node": "^22.10.7",
    "typescript": "^5.6.3"
  }
}
