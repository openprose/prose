{
  "name": "@openprose/reactor-cli",
  "version": "0.1.0",
  "type": "commonjs",
  "description": "Deterministic command-line driver for the @openprose/reactor SDK.",
  "main": "dist/cli.js",
  "bin": {
    "reactor": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "examples"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:test": "tsc -p tsconfig.test.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:runtime": "pnpm build:test && node --test $(find dist-test -name '*.test.js' -type f | sort)",
    "test": "pnpm typecheck && pnpm test:runtime",
    "test:offline": "REACTOR_OFFLINE=1 pnpm test",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "peerDependencies": {
    "@openprose/reactor": "workspace:*",
    "@openai/agents": "*",
    "zod": "*"
  },
  "peerDependenciesMeta": {
    "@openai/agents": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@openprose/reactor": "workspace:*",
    "typescript": "^5.6.3"
  }
}
