{
  "name": "@openprose/co",
  "version": "0.11.0-dev",
  "registry": {
    "catalog": "openprose"
  },
  "description": "OpenProse company-as-code starter package for organizing an operating company as Prose programs.",
  "license": "MIT",
  "evals": [
    "evals/company-repo-checker.eval.prose.md",
    "evals/company-system-map.eval.prose.md"
  ],
  "runtime": {
    "graph_vm": "pi",
    "model_providers": [
      "openrouter"
    ],
    "default_model_provider": "openrouter",
    "default_model": "google/gemini-3-flash-preview",
    "thinking": "low",
    "tools": [
      "read",
      "write"
    ],
    "persist_sessions": true
  },
  "examples": [
    "programs/company-repo-checker.prose.md",
    "programs/company-system-map.prose.md"
  ]
}
