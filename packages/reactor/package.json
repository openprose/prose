{
  "name": "@openprose/reactor",
  "version": "0.3.1",
  "description": "OpenProse Reactor runtime: fresh model spend scales with surprise, not the clock.",
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "agents": ["./dist/agents/index.d.ts"],
      "adapters": ["./dist/adapters/index.d.ts"],
      "run": ["./dist/run/index.d.ts"],
      "run/types": ["./dist/run/types.d.ts"],
      "internals": ["./dist/internals/index.d.ts"]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./agents": {
      "types": "./dist/agents/index.d.ts",
      "default": "./dist/agents/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "default": "./dist/adapters/index.js"
    },
    "./run": {
      "types": "./dist/run/index.d.ts",
      "default": "./dist/run/index.js"
    },
    "./run/types": {
      "types": "./dist/run/types.d.ts",
      "default": "./dist/run/types.js"
    },
    "./internals": {
      "types": "./dist/internals/index.d.ts",
      "default": "./dist/internals/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "!dist/**/__tests__/**",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.d.ts.map",
    "skill/**",
    "ADOPTION.md",
    "EVALS.md",
    "README.md"
  ],
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openprose/prose.git",
    "directory": "packages/reactor"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "bundle-skill": "node scripts/bundle-skill.mjs",
    "prepack": "pnpm build && node scripts/bundle-skill.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:runtime": "pnpm build && node --test $(find dist -name '*.test.js' -type f | sort)",
    "test": "pnpm typecheck && pnpm test:runtime",
    "test:offline": "REACTOR_OFFLINE=1 pnpm test"
  },
  "peerDependencies": {
    "@openai/agents": "^0.11.6",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@openai/agents": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@openai/agents": "^0.11.6",
    "@openai/agents-openai": "^0.11.6",
    "@types/node": "^22.10.7",
    "typescript": "^5.9.3",
    "zod": "^4.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
