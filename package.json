{
  "name": "@openprose/prose",
  "version": "0.11.0-dev",
  "description": "OpenProse compiler and local reactive runtime.",
  "private": true,
  "license": "MIT",
  "homepage": "https://github.com/openprose/prose#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openprose/prose.git"
  },
  "bugs": {
    "url": "https://github.com/openprose/prose/issues"
  },
  "keywords": [
    "agents",
    "openprose",
    "reactive-runtime",
    "pi",
    "workflow"
  ],
  "type": "module",
  "scripts": {
    "prose": "bun bin/prose.ts",
    "build:binary": "bun build --compile --target=bun --outfile dist/prose ./bin/prose.ts && bun scripts/write-dist-package.ts",
    "smoke:binary": "bun run build:binary && ./dist/prose help >/dev/null && ./dist/prose compile examples/north-star/company-signal-brief.prose.md --no-pretty >/dev/null",
    "smoke:cold-start": "bun scripts/cold-start-smoke.ts",
    "smoke:company:local": "bun scripts/openprose-native-company-smoke.ts",
    "compile": "bun bin/prose.ts compile",
    "fmt": "bun bin/prose.ts fmt",
    "grammar": "bun bin/prose.ts grammar",
    "graph": "bun bin/prose.ts graph",
    "highlight": "bun bin/prose.ts highlight",
    "lint": "bun bin/prose.ts lint",
    "measure:examples": "bun scripts/measure-examples.ts",
    "smoke:live-pi": "bun scripts/live-pi-smoke.ts",
    "confidence:runtime": "bun scripts/runtime-confidence-matrix.ts",
    "manifest": "bun bin/prose.ts manifest",
    "plan": "bun bin/prose.ts plan",
    "package": "bun bin/prose.ts package",
    "publish-check": "bun bin/prose.ts publish-check",
    "search": "bun bin/prose.ts search",
    "trace": "bun bin/prose.ts trace",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "latest"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "0.70.2",
    "typebox": "^1.1.24"
  }
}
