{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AccountRecord",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "company": {
      "type": "string"
    },
    "segment": {
      "type": "string"
    },
    "employees": {
      "type": "integer",
      "minimum": 1
    },
    "region": {
      "type": "string"
    },
    "signals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "company",
    "segment",
    "employees",
    "region",
    "signals"
  ]
}
