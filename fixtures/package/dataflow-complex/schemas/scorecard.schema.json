{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Scorecard",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "fit": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "rationale": {
      "type": "string"
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "fit",
    "score",
    "rationale",
    "risks"
  ]
}
