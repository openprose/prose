  "responsibilities": [
    {
      "id": "high-intent-stargazer-outreach",
      "sourcePath": "tests/open-prose/responsibility-runtime/01-stargazer-responsibility.prose.md",
      "goal": "High-intent GitHub stargazers are identified, enriched, and thoughtfully followed up with using relevant OpenProse sample results.",
      "continuity": [
        "New high-intent stargazers should not remain unattended for more than one business day.",
        "Outreach history should prevent duplicate contact unless new evidence changes the prospect's fit.",
        "Stale leads should be revisited when company, role, or repository evidence materially changes."
      ],
      "criteria": [
        "Qualification includes GitHub activity, likely organization, company context, role signals, customers, and plausible operational pain.",
        "Proposed OpenProse programs are specific to the prospect's observed work.",
        "Sample results exist before outreach when the prospect appears high intent.",
        "Outreach asks whether the sample result is useful rather than pushing a generic sales message."
      ],
      "constraints": [
        "Do not send generic or irrelevant outreach.",
        "Do not contact the same person repeatedly without new evidence.",
        "Keep enrichment and sample-generation cost bounded by expected value.",
        "Escalate uncertainty instead of fabricating company, role, or pain details."
      ],
      "fulfillment": {
        "mode": "declared",
        "targetName": "stargazer-outreach",
        "sourcePath": "tests/open-prose/responsibility-runtime/stargazer-outreach/index.prose.md"
      }
    }
  ],
